#!/usr/bin/expect -f

# This script wraps the 'claude' CLI and automatically sends "y" whenever it sees a permission prompt.

# Disable timeout so the script doesn't exit when idle
set timeout -1

# Spawn the original claude CLI, passing any arguments you provide (e.g. claude-yes -p "my prompt")
spawn claude {*}$argv

# Start the interactive session
interact {
    # -o tells expect to match against the OUTPUT of claude, not your input
    -o
    # Match specifically "Do you want to proceed?", ignoring case
    -re "(?i)Do you want to proceed\\\?" {
        # The prompt is an interactive menu, not a text input.
        # We sleep for a tiny fraction to allow the menu to finish rendering, 
        # then simply press Enter (\r) to select the default "1. Yes"
        sleep 0.2
        send "\r"
    }
}
